# Google reCAPTCHA v3 for Download Protection
# Get keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Download Protection Secret
# Generate with: openssl rand -hex 32
DOWNLOAD_SECRET=generate_random_64_character_string_here

# Admin API Token for Download Monitoring (Optional)
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your_secure_admin_token_here

# Existing environment variables
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://api.bnglogisticsnetwork.com/graphql
